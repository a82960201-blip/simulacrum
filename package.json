{
  "name": "simulacrum",
  "version": "1.0.0",
  "description": "SIMULACRUM — Backrooms / Dreamcore horror game",
  "main": "index.js",
  "scripts": {
    "build": "echo 'No build step needed - pure HTML/JS/CSS'",
    "cap:init": "npx cap init simulacrum com.simulacrum.game",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "apk": "npm run cap:sync && npm run cap:open:android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "typescript": "^6.0.2"
  }
}
